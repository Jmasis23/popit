DATABASE_URL="file:./dev.db"

# Get a key at https://console.cloud.google.com/ with "Places API" enabled.
GOOGLE_PLACES_API_KEY=

# OAuth client for "Google Business Profile" (full review access, requires
# the business owner to sign in). Create one at
# https://console.cloud.google.com/apis/credentials with a redirect URI of
# {your app origin}/api/oauth/google/callback, and enable the Business
# Profile APIs (My Business Account Management, Business Information).
# Production access to these APIs requires applying to Google:
# https://support.google.com/business/answer/9053347
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Get a key at https://www.yelp.com/developers/v3/manage_app (Yelp Fusion API).
YELP_API_KEY=

# Get a key at https://developers.trustpilot.com/ (Trustpilot Business API).
TRUSTPILOT_API_KEY=

# Facebook has no server-side API key here — business owners paste their own
# Page ID + Page Access Token directly in the dashboard when connecting.
